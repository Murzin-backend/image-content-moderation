# ── Application ──────────────────────────────────────────────────
APP_NAME=image-content-moderation
DEBUG=true
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ── CLIP ─────────────────────────────────────────────────────────
CLIP_MODEL_NAME=ViT-B/32
# Leave empty for auto-detect (cuda if available, otherwise cpu)
CLIP_DEVICE=

# ── EasyOCR ──────────────────────────────────────────────────────
EASYOCR_LANGUAGES=en,ru

# ── Thresholds ───────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.55
SUSPICIOUS_THRESHOLD=0.35

# ── Upload limits ────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10

